{
  "name": "trace-v2",
  "private": true,
  "type": "module",
  "bin": {
    "trace": "apps/cli/src/trace.ts"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "render:skills": "node apps/cli/src/render-skills.ts",
    "release:trace": "node apps/cli/src/release.ts",
    "eval": "node evals/run.ts",
    "test:evals": "vitest run evals/src"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.7",
    "prettier": "^3.7.4",
    "turbo": "^2.9.16",
    "typescript": "5.9.2",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=22"
  }
}
