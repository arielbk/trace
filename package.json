{
  "name": "trace",
  "private": true,
  "license": "MIT",
  "type": "module",
  "bin": {
    "trace": "apps/cli/src/trace.ts"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "release:trace": "node apps/cli/src/release.ts",
    "dev:stamp": "node apps/cli/src/dev-stamp.ts stamp",
    "dev:unstamp": "node apps/cli/src/dev-stamp.ts unstamp",
    "eval": "node evals/run.ts",
    "test:evals": "vitest run evals/src"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "prettier": "^3.9.5",
    "turbo": "^2.10.5",
    "typescript": "5.9.3",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "engines": {
    "node": ">=22"
  }
}
