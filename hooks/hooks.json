{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "npx @arielbk/trace@0.8.0 hook session-start"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx @arielbk/trace@0.8.0 hook subagent-stop"
          }
        ]
      }
    ]
  }
}
