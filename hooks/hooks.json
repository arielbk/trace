{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/arielbk/Projects/side/trace-v2/apps/cli/dist/trace.js hook session-start"
          }
        ]
      }
    ],
    "SubagentStop": [
