{
  "name": "@arielbk/trace",
  "version": "0.15.0",
  "type": "module",
  "license": "MIT",
  "bin": {
    "trace": "dist/trace.js"
  },
  "files": [
    "dist/trace.js",
    "dist/web/**"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "test:bundle": "vitest run src/bundle.test.ts",
    "test": "vitest run",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "citty": "^0.2.2"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@trace/core": "workspace:*",
    "@trace/cursor-reader": "workspace:*",
    "@trace/web": "workspace:*",
    "@types/node": "^22.20.1",
    "@typescript/native": "npm:typescript@7.0.2",
    "eslint": "^9.39.5",
    "tsup": "^8.5.1",
    "vitest": "^4.1.10"
  }
}
