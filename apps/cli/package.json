{
  "name": "@arielbk/trace",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "trace": "./dist/trace.js"
  },
  "files": [
    "dist/trace.js",
    "dist/claude-session-start-hook.js",
    "dist/web/**"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "test:bundle": "vitest run src/bundle.test.ts",
    "test": "vitest run",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@trace/core": "workspace:*",
    "@trace/web": "workspace:*",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "tsup": "^8.5.1",
    "typescript": "5.9.2",
    "vitest": "^4.1.7"
  }
}
